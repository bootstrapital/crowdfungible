<% content_for :title, "Submit Paper Trade" %>

<section class="panel panel--centered">
  <p class="eyebrow">Paper Trading Only</p>
  <%= form_with model: @trade_request do |form| %>
    <%= form.hidden_field :order_type, value: "market" %>
    <%= form.hidden_field :submitted_by, value: @trade_request.submitted_by.presence || "demo_user@example.com" %>

    <div class="field">
      <%= form.label :request_text, "Trade request" %>
      <%= form.text_area :request_text, placeholder: "Buy 10 shares of AAPL", class: "trade-request-input" %>
      <p class="helper-text helper-text--centered">
        Describe the trade in plain English. Small, clear paper orders may execute automatically; anything ambiguous or risky routes to review.
      </p>
    </div>

    <div class="actions actions--centered">
      <%= form.submit "Submit Trade", class: "button" %>
      <%= link_to "View Recent Requests", trade_requests_path, class: "button button--secondary" %>
    </div>
  <% end %>
</section>
