<% content_for :title, "Submit Paper Trade" %>

<section class="hero">
  <div class="hero-card hero-copy">
    <p class="eyebrow">Paper Trading Only</p>
    <h1>Submit a trade request inside a visible policy perimeter.</h1>
    <p>
      CrowdFungible is a demo host app. The product UI submits the request, while Rubot admin remains the operator surface for approvals, replay, and traces.
    </p>
    <ul class="meta-list">
      <li>Small clear market orders may auto-execute against paper trading.</li>
      <li>Ambiguous or larger requests route to approval.</li>
      <li>Unsupported symbols or unsafe requests reject with explicit reasons.</li>
    </ul>
  </div>

  <section class="panel">
    <p class="eyebrow">Trade Request</p>
    <%= form_with model: @trade_request do |form| %>
      <div class="form-grid">
        <div class="field field--full">
          <%= form.label :request_text, "Freeform request" %>
          <%= form.text_area :request_text, placeholder: "Buy 10 shares of AAPL" %>
          <p class="helper-text">You can also try: "Put $500 into NVDA if cash is available."</p>
        </div>

        <div class="field">
          <%= form.label :side %>
          <%= form.select :side, [["Auto-detect", nil], ["Buy", "buy"], ["Sell", "sell"]] %>
        </div>

        <div class="field">
          <%= form.label :symbol %>
          <%= form.text_field :symbol, placeholder: "AAPL" %>
        </div>

        <div class="field">
          <%= form.label :quantity %>
          <%= form.number_field :quantity, step: "0.0001", placeholder: "10" %>
        </div>

        <div class="field">
          <%= form.label :notional_usd, "Notional USD" %>
          <%= form.number_field :notional_usd, step: "0.01", placeholder: "500" %>
        </div>

        <div class="field">
          <%= form.label :order_type %>
          <%= form.select :order_type, [["Market", "market"]] %>
        </div>

        <div class="field">
          <%= form.label :submitted_by %>
          <%= form.email_field :submitted_by, placeholder: "demo_user@example.com" %>
        </div>
      </div>

      <div class="actions">
        <%= form.submit "Submit Trade", class: "button" %>
        <%= link_to "View Recent Requests", trade_requests_path, class: "button button--secondary" %>
      </div>
    <% end %>
  </section>
</section>
